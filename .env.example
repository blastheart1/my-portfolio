# Copy this file to .env.local and fill in your values.
# .env.example is safe to commit — it contains no real secrets.

# ── Neon Database ─────────────────────────────────────────────────────────────
# Neon Console → your project → Dashboard → Connection string → Pooled
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon Console → Connection string → Direct (unpooled) — used for migrations
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Admin Auth ────────────────────────────────────────────────────────────────
# node -e "const b=require('bcryptjs'); b.hash('YOUR_PASSWORD',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=at-least-32-random-characters-here

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# ── Email via Resend ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
TO_EMAIL=you@example.com
NEXT_PUBLIC_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_TO_EMAIL=you@example.com
NEXT_PUBLIC_RESEND_API_KEY=re_xxxxxxxx

# ── OpenAI ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_OPENAI_API_KEY=sk-proj-xxxxxxxx

# ── Supabase (optional — blog posts) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-xxxxxxxx

# ── Cron auth ─────────────────────────────────────────────────────────────────
CRON_SECRET=any-random-string
